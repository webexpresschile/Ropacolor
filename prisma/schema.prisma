datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("USER") // ADMIN, USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  image       String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  shortDesc       String
  longDesc        String
  category        Category         @relation(fields: [categoryId], references: [id])
  categoryId      String
  brand           String           @default("Ropa Unicolor")
  tags            String           @default("") // Comma-separated values
  sizeType        String           @default("letras") // letras, numeros, cm
  priceNormal     Int              // Pesos chilenos (integer)
  priceWholesale  Int              // Precio mayorista
  minWholesaleQty Int              @default(3)
  active          Boolean          @default(true)
  featured        Boolean          @default(false)
  images          String           @default("") // Comma-separated images or JSON string
  metaTitle       String?
  metaDescription String?
  openGraph       String?
  variants        ProductVariant[]
  orderItems      OrderItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProductVariant {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  color     String   // e.g., "Negro", "Blanco", "Azul"
  size      String   // e.g., "XS", "S", "M", "L", "XL", "XXL"
  stock     Int      @default(0)
  sku       String   @unique
  image     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  lastName  String
  rut       String?
  email     String   @unique
  phone     String
  region    String
  city      String
  address   String
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id         String      @id @default(uuid())
  orderNo    String      @unique // Autogenerated prefix
  customer   Customer    @relation(fields: [customerId], references: [id])
  customerId String
  items      OrderItem[]
  subtotal   Int
  discount   Int         @default(0)
  total      Int
  status     String      @default("PENDIENTE") // PENDIENTE, PAGADO, PREPARANDO, ENVIADO, ENTREGADO, CANCELADO
  comments   String?
  couponCode String?
  payment    Payment?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  color     String
  size      String
  quantity  Int
  priceUnit Int
  priceTotal Int
}

model Coupon {
  id         String    @id @default(uuid())
  code       String    @unique
  type       String    // FIXED, PERCENT
  value      Int
  expiry     DateTime?
  maxUses    Int       @default(100)
  usedCount  Int       @default(0)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Payment {
  id            String   @id @default(uuid())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String   @unique
  preferenceId  String?  @unique
  paymentId     String?  @unique
  status        String   @default("PENDIENTE") // PENDIENTE, PAGADO, RECHAZADO, CANCELADO
  method        String?  // Mercado Pago, etc.
  rawResponse   String?  // JSON string
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
