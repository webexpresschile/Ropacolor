# Base de datos PostgreSQL (obligatorio)
# Usa Neon, Railway, Supabase o tu propio servidor PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/ropacolor?schema=public"

# NextAuth
NEXTAUTH_SECRET="genera-un-secreto-seguro-con: openssl rand -base64 32"
NEXTAUTH_URL="https://tu-dominio.cl"  # En desarrollo: http://localhost:3000

# Mercado Pago
# Access Token de producción (APP_USR-) o de prueba (TEST-)
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxx"

# Resend (emails transaccionales)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Cloudinary (imágenes)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Opcional: Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
